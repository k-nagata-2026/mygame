// スライム
class Slime extends Enemy {
    public Slime() {
        this.name = "スライム";
        /* hp, atk, def などの値を決める */
    }
    @Override
    public String attack(Human target) { return name + "の体当たり！"; }
    @Override
    public String skill(Human target) { return name + "が分裂した！（が、何も起きなかった）"; }
}

